#!/bin/bash
iface=$(route get default 2>/dev/null | awk '/interface:/{print $2}')
ip=$(ifconfig "$iface" 2>/dev/null | awk '/inet /{print $2}')
free=$(memory_pressure 2>/dev/null | awk -F': ' '/free percentage/{print $2}' | tr -d '%')
[ -n "$free" ] && used=$((100 - free)) && ram="${used}%" || ram="?"
[ -n "$ip" ] && printf '箚쎋 %s 箚뜘 %s' "$ip" "$ram" || printf '箚뜘 %s' "$ram"
