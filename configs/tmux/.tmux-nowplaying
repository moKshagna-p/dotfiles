#!/bin/bash
res=$(osascript -e '
tell application "Spotify"
  if running then
    try
      if player state is playing then
        return "♫ " & artist of current track & " - " & name of current track
      end if
    end try
  end if
end tell
' 2>/dev/null)
if [ -n "$res" ]; then
  echo "$res"
  exit 0
fi
osascript -e '
tell application "Music"
  if running then
    try
      if player state is playing then
        return "♫ " & artist of current track & " - " & name of current track
      end if
    end try
  end if
end tell
' 2>/dev/null
